---
import { site } from "../data/site";

type JsonLd = Record<string, unknown>;

type Props = {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogType?: "website" | "article" | "profile";
  image?: string;
  noindex?: boolean;
  jsonLd?: JsonLd | JsonLd[];
};

const {
  title = site.title,
  description = site.description,
  canonicalUrl: canonicalUrlProp,
  ogType = "website",
  image,
  noindex = false,
  jsonLd
} = Astro.props as Props;

const currentPath = Astro.url.pathname;
const canonicalUrl = canonicalUrlProp ?? new URL(currentPath, site.url).toString();
const socialImageUrl = image ?? new URL("/social-card.svg", site.url).toString();
const robotsContent = noindex ? "noindex, nofollow" : "index, follow";
const jsonLdItems = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={socialImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
    {jsonLdItems.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
  </head>
  <body>
    <header class="site-header">
      <div class="container nav-bar">
        <a class="logo" href="/">MK</a>
        <button
          class="menu-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="site-nav"
          aria-label="Open navigation menu"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
        <nav id="site-nav">
          <a href="/" class:list={[{ active: currentPath === "/" }]}>Home</a>
          <a href="/talks" class:list={[{ active: currentPath === "/talks/" }]}>Community</a>
          <a href="/blog" class:list={[{ active: currentPath.startsWith("/blog") }]}>Archive</a>
          <a href="https://dev.to/mkreder" target="_blank" rel="noreferrer">Dev.to</a>
          <a href="https://github.com/mkreder" target="_blank" rel="noreferrer">GitHub</a>
          <a href="https://www.linkedin.com/in/mkreder" target="_blank" rel="noreferrer">LinkedIn</a>
          <a href="/about" class:list={[{ active: currentPath === "/about" }]}>About</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-inner">
        <span class="footer-name">&copy; {new Date().getFullYear()} {site.title}</span>
        <div class="footer-links">
          {site.links.map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
          ))}
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0d0d0d;
    --surface: #161616;
    --surface-hover: #1c1c1c;
    --text: #e5e5e5;
    --text-secondary: #a0a0a0;
    --text-muted: #666666;
    --accent: #60a5fa;
    --accent-hover: #93bbfd;
    --border: #262626;
    --border-hover: #333333;
    --code-bg: #111111;
    --code-text: #cdd6f4;
    --radius: 12px;
    --radius-sm: 8px;
    --max-width: 960px;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--text);
    background: var(--bg);
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  /* Container — single width everywhere */
  .container {
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Header */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(13, 13, 13, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    position: relative;
  }

  .logo {
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .nav-bar nav {
    display: flex;
    gap: 1.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  .menu-toggle {
    display: none;
    width: 40px;
    height: 40px;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--text);
    cursor: pointer;
  }

  .menu-toggle span {
    display: block;
    width: 18px;
    height: 2px;
    margin: 4px auto;
    border-radius: 999px;
    background: currentColor;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .nav-bar nav a:hover {
    color: var(--text);
  }

  .nav-bar nav a.active {
    color: var(--text);
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 0;
    margin-top: 4rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer-links a:hover {
    color: var(--text-secondary);
  }

  /* Section */
  .section {
    padding: 3rem 0;
  }

  .section + .section {
    border-top: 1px solid var(--border);
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .section-header h2 {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .section-link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--accent);
    white-space: nowrap;
  }

  @media (max-width: 860px) {
    .nav-bar {
      height: 56px;
    }

    .menu-toggle {
      display: inline-block;
    }

    .nav-bar nav {
      display: none;
      position: absolute;
      top: calc(100% + 0.75rem);
      right: 0;
      left: 0;
      flex-direction: column;
      gap: 0;
      padding: 0.75rem 0;
      background: rgba(13, 13, 13, 0.98);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
    }

    .nav-bar nav a {
      padding: 0.85rem 1rem;
    }

    .nav-bar.menu-open nav {
      display: flex;
    }

    .nav-bar.menu-open .menu-toggle span:nth-child(1) {
      transform: translateY(6px) rotate(45deg);
    }

    .nav-bar.menu-open .menu-toggle span:nth-child(2) {
      opacity: 0;
    }

    .nav-bar.menu-open .menu-toggle span:nth-child(3) {
      transform: translateY(-6px) rotate(-45deg);
    }
  }

  @media (max-width: 640px) {
    .container {
      padding: 0 1rem;
    }

    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .footer-links {
      flex-wrap: wrap;
      gap: 0.75rem 1rem;
    }
  }

  .section-link:hover {
    color: var(--accent-hover);
  }

  /* Post list */
  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--border);
    overflow: hidden;
  }

  .post-item {
    display: block;
    padding: 1rem 1.25rem;
    background: var(--surface);
    transition: background 0.15s;
  }

  .post-item:hover {
    background: var(--surface-hover);
  }

  .post-item-title {
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 0.25rem;
  }

  .post-item-desc {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-item-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.375rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .post-item-meta .badge {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    background: rgba(96, 165, 250, 0.15);
    color: var(--accent);
  }

  .post-item-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-secondary);
  }

  /* Article */
  .article-header {
    padding: 3rem 0 2rem;
  }

  .article-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    flex-wrap: wrap;
  }

  .article-meta a {
    color: var(--accent);
  }

  .article-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }

  .article-content {
    padding-bottom: 3rem;
  }

  .article-content :where(p, li) {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  .article-content p + p {
    margin-top: 1.25rem;
  }

  .article-content :where(h2, h3, h4) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .article-content h2 {
    font-size: 1.5rem;
  }

  .article-content h3 {
    font-size: 1.25rem;
  }

  .article-content ul, .article-content ol {
    padding-left: 1.5rem;
    margin-top: 0.75rem;
  }

  .article-content li + li {
    margin-top: 0.375rem;
  }

  .article-content a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-content pre {
    overflow-x: auto;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-sm);
    background: var(--code-bg);
    color: var(--code-text);
    font-family: "JetBrains Mono", monospace;
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 1.25rem 0;
    border: 1px solid var(--border);
  }

  .article-content code {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.875em;
    background: rgba(255, 255, 255, 0.06);
    padding: 0.15em 0.35em;
    border-radius: 4px;
  }

  .article-content pre code {
    background: none;
    padding: 0;
    border-radius: 0;
  }

  .article-content blockquote {
    border-left: 3px solid var(--border);
    padding-left: 1rem;
    margin: 1.25rem 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .article-content img {
    border-radius: var(--radius-sm);
    margin: 1.5rem 0;
  }

  /* YouTube embed */
  .yt-embed {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    margin: 1.5rem 0;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--surface);
  }

  .yt-embed iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .container {
      padding: 0 1rem;
    }

    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .footer-links {
      flex-wrap: wrap;
      gap: 0.75rem 1rem;
    }

    .section {
      padding: 2rem 0;
    }
  }
</style>

<script>
  const navBar = document.querySelector(".nav-bar");
  const menuToggle = document.querySelector(".menu-toggle");
  const navLinks = document.querySelectorAll("#site-nav a");

  if (navBar instanceof HTMLElement && menuToggle instanceof HTMLButtonElement) {
    const setMenuOpen = (isOpen) => {
      navBar.classList.toggle("menu-open", isOpen);
      menuToggle.setAttribute("aria-expanded", String(isOpen));
      menuToggle.setAttribute("aria-label", isOpen ? "Close navigation menu" : "Open navigation menu");
    };

    menuToggle.addEventListener("click", () => {
      setMenuOpen(!navBar.classList.contains("menu-open"));
    });

    navLinks.forEach((link) => {
      link.addEventListener("click", () => setMenuOpen(false));
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 860) {
        setMenuOpen(false);
      }
    });
  }
</script>
