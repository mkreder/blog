---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { certifications, site } from "../data/site";
import { getDevtoPosts } from "../lib/devto";

const posts = (await getCollection("posts"))
  .filter((entry) => !entry.data.draft)
  .sort(
    (left, right) =>
      right.data.publishedAt.getTime() - left.data.publishedAt.getTime()
  );

const featuredPosts = posts.filter((post) => post.data.featured).slice(0, 3);
const recentPosts = posts.slice(0, 6);
const devtoPosts = await getDevtoPosts(4);
const featuredCertifications = certifications.filter((item) => item.featured);
---

<BaseLayout title={`${site.title} | Cloud, AI, and Modernization`}>
  <section class="hero">
    <p class="eyebrow">Cloud · AI · Modernization</p>
    <h1>One home for markdown posts, old WordPress writing, and new dev.to articles.</h1>
    <p class="lede">
      CTO, builder, and professor writing about agentic AI, AWS, platform engineering,
      modernization, and practical software delivery. This site is git-backed, fast to
      publish, and keeps legacy content reachable without staying on WordPress.
    </p>
    <div class="meta">
      <a class="button" href="/blog">Read the blog</a>
      <a class="button secondary" href="/about">About Matias</a>
    </div>
    <div class="stats">
      <div class="card">
        <p class="eyebrow">Experience</p>
        <strong>20+ yrs</strong>
        <p>Leadership and hands-on delivery across cloud, AI, software, and DevOps.</p>
      </div>
      <div class="card">
        <p class="eyebrow">Current focus</p>
        <strong>GenAI</strong>
        <p>Bedrock, agent platforms, modernization systems, and cloud-native product design.</p>
      </div>
      <div class="card">
        <p class="eyebrow">Publishing</p>
        <strong>Git + RSS</strong>
        <p>Write here in markdown, syndicate externally, or surface dev.to posts automatically.</p>
      </div>
    </div>
  </section>

  <div class="section-heading">
    <div>
      <p class="eyebrow">Featured</p>
      <h2>Posts you own</h2>
    </div>
    <a href="/blog">See all posts</a>
  </div>
  <section class="grid grid-3">
    {(featuredPosts.length > 0 ? featuredPosts : recentPosts.slice(0, 3)).map((post) => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        href={`/blog/${post.id}/`}
        publishedAt={post.data.publishedAt}
        tags={post.data.tags}
      />
    ))}
  </section>

  <div class="section-heading">
    <div>
      <p class="eyebrow">Syndicated</p>
      <h2>Latest from dev.to</h2>
    </div>
    <a href={`https://dev.to/${site.devtoUsername}`} target="_blank" rel="noreferrer">
      Open profile
    </a>
  </div>
  <section class="grid grid-2">
    {devtoPosts.length > 0 ? (
      devtoPosts.map((post) => (
        <PostCard
          title={post.title}
          description={post.description}
          href={post.url}
          publishedAt={post.publishedAt}
          tags={post.tags}
          source={post.source}
        />
      ))
    ) : (
      <article class="card">
        <p class="eyebrow">Feed unavailable</p>
        <h3>Connect a dev.to username and the latest external articles will appear here.</h3>
        <p>
          The fetch is already wired. Once the site can reach the feed during build, it will
          render without any manual copying.
        </p>
      </article>
    )}
  </section>

  <div class="section-heading">
    <div>
      <p class="eyebrow">Profile</p>
      <h2>High-level about section</h2>
    </div>
    <a href="/certifications">View certifications</a>
  </div>
  <section class="grid grid-2">
    <article class="panel card">
      <p class="eyebrow">What you do</p>
      <h3>CTO and builder for AI products, cloud platforms, and modernization programs.</h3>
      <p>
        Matias leads engineering organizations, still ships code, teaches at UADE, and has
        worked across AWS, Azure, data platforms, and agentic AI systems.
      </p>
      <a class="button secondary" href="/about">Read more</a>
    </article>
    <article class="panel card">
      <p class="eyebrow">Selected certifications</p>
      <div class="grid">
        {featuredCertifications.map((item) => (
          <div>
            <strong>{item.name}</strong>
            <p>{item.issuer} · Expires {item.expires}</p>
          </div>
        ))}
      </div>
    </article>
  </section>
</BaseLayout>
