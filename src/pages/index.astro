---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import { talks } from "../data/talks";
import { getDevtoPosts } from "../lib/devto";
import { formatDate } from "../lib/format";

const posts = (await getCollection("posts"))
  .filter((entry) => !entry.data.draft)
  .sort(
    (left, right) =>
      right.data.publishedAt.getTime() - left.data.publishedAt.getTime()
  );

const devtoPosts = await getDevtoPosts(6);
const featuredTalks = [...talks]
  .filter((talk) => talk.featured)
  .sort((left, right) => new Date(right.date).getTime() - new Date(left.date).getTime())
  .slice(0, 6);
const pageTitle = `${site.title} — Cloud, AI & Engineering`;
const pageDescription =
  "Cloud, AI, and engineering writing from Matias Kreder on agentic AI, platform engineering, AWS, and practical software delivery.";
const pageUrl = new URL("/", site.url).toString();
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={pageUrl}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.title,
    url: site.url,
    description: pageDescription,
    author: {
      "@type": "Person",
      name: site.title
    }
  }}
>
  <!-- Hero -->
  <section class="section">
    <div class="container">
      <p class="hero-greeting">Hey, I'm Matias</p>
      <h1 class="hero-title">
        I share ideas about cloud, AI,<span class="hero-break"><br/></span> and building software<span class="hero-break"><br/></span> that ships.
      </h1>
      <p class="hero-desc">
        CTO, AWS Community Builder, AWS User Group Leader, DeepRacer finalist, and professor based in Buenos Aires.
      </p>
    </div>
  </section>

  <!-- Latest from dev.to -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Latest posts</h2>
        <a class="section-link" href={`https://dev.to/${site.devtoUsername}`} target="_blank" rel="noreferrer">
          dev.to/{site.devtoUsername} &rarr;
        </a>
      </div>
      {devtoPosts.length > 0 ? (
        <div class="post-list">
          {devtoPosts.map((post) => (
            <a class="post-item" href={post.url} target="_blank" rel="noreferrer">
              <div class="post-item-title">{post.title}</div>
              <div class="post-item-desc">{post.description}</div>
              <div class="post-item-meta">
                <span class="badge">dev.to</span>
                <span>{formatDate(post.publishedAt)}</span>
                {post.tags.length > 0 && (
                  <div class="post-item-tags">
                    {post.tags.slice(0, 3).map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="empty-state">
          dev.to feed is currently unavailable. Posts will appear here automatically at build time.
        </p>
      )}
    </div>
  </section>

  {featuredTalks.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>Community</h2>
          <a class="section-link" href="/talks">View all &rarr;</a>
        </div>
        <div class="post-list">
          {featuredTalks.map((talk) => (
            <a class="post-item talk-item" href={talk.url} target="_blank" rel="noreferrer">
              <div class="talk-location">{talk.location}</div>
              <div class="post-item-title">{talk.title}</div>
              <div class="post-item-desc">{talk.summary}</div>
              <div class="post-item-meta">
                <span>{formatDate(talk.date)}</span>
                <span>{talk.activityType}</span>
                <span>{talk.language}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Archive -->
  {posts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>From the archive</h2>
          <a class="section-link" href="/blog">View all &rarr;</a>
        </div>
        <div class="post-list">
          {posts.slice(0, 8).map((post) => (
            <a class="post-item" href={`/blog/${post.id}/`}>
              <div class="post-item-title">{post.data.title}</div>
              <div class="post-item-desc">{post.data.description}</div>
              <div class="post-item-meta">
                <span>{formatDate(post.data.publishedAt)}</span>
                {post.data.tags.length > 0 && (
                  <div class="post-item-tags">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero-greeting {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .hero-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
    text-wrap: balance;
  }

  .hero-desc {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 540px;
  }

  .empty-state {
    font-size: 0.875rem;
    color: var(--text-muted);
    padding: 1.5rem;
    border: 1px dashed var(--border);
    border-radius: var(--radius);
    text-align: center;
  }

  .talk-item {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .talk-location {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 2.35rem;
      line-height: 1.08;
    }

    .hero-break {
      display: none;
    }

    .hero-desc {
      font-size: 1rem;
      max-width: 100%;
    }
  }
</style>
