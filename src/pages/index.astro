---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import { getDevtoPosts } from "../lib/devto";
import { formatDate } from "../lib/format";

const posts = (await getCollection("posts"))
  .filter((entry) => !entry.data.draft)
  .sort(
    (left, right) =>
      right.data.publishedAt.getTime() - left.data.publishedAt.getTime()
  );

const devtoPosts = await getDevtoPosts(6);
---

<BaseLayout title={`${site.title} — Cloud, AI & Engineering`}>
  <!-- Hero -->
  <section class="section">
    <div class="container">
      <p class="hero-greeting">Hey, I'm Matias</p>
      <h1 class="hero-title">I write about cloud, AI,<br/>and building software<br/>that ships.</h1>
      <p class="hero-desc">
        CTO, AWS Community Builder, and professor based in Buenos Aires.
        I write about agentic AI, platform engineering, and practical cloud delivery.
      </p>
    </div>
  </section>

  <!-- Latest from dev.to -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Latest posts</h2>
        <a class="section-link" href={`https://dev.to/${site.devtoUsername}`} target="_blank" rel="noreferrer">
          dev.to/{site.devtoUsername} &rarr;
        </a>
      </div>
      {devtoPosts.length > 0 ? (
        <div class="post-list">
          {devtoPosts.map((post) => (
            <a class="post-item" href={post.url} target="_blank" rel="noreferrer">
              <div class="post-item-title">{post.title}</div>
              <div class="post-item-desc">{post.description}</div>
              <div class="post-item-meta">
                <span class="badge">dev.to</span>
                <span>{formatDate(post.publishedAt)}</span>
                {post.tags.length > 0 && (
                  <div class="post-item-tags">
                    {post.tags.slice(0, 3).map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="empty-state">
          dev.to feed is currently unavailable. Posts will appear here automatically at build time.
        </p>
      )}
    </div>
  </section>

  <!-- Archive -->
  {posts.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>From the archive</h2>
          <a class="section-link" href="/blog">View all &rarr;</a>
        </div>
        <div class="post-list">
          {posts.slice(0, 8).map((post) => (
            <a class="post-item" href={`/blog/${post.id}/`}>
              <div class="post-item-title">{post.data.title}</div>
              <div class="post-item-desc">{post.data.description}</div>
              <div class="post-item-meta">
                <span>{formatDate(post.data.publishedAt)}</span>
                {post.data.tags.length > 0 && (
                  <div class="post-item-tags">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero-greeting {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .hero-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .hero-desc {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 540px;
  }

  .empty-state {
    font-size: 0.875rem;
    color: var(--text-muted);
    padding: 1.5rem;
    border: 1px dashed var(--border);
    border-radius: var(--radius);
    text-align: center;
  }
</style>
