---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../lib/format";
import { site } from "../../data/site";

const posts = (await getCollection("posts"))
  .filter((entry) => !entry.data.draft)
  .sort(
    (left, right) =>
      right.data.publishedAt.getTime() - left.data.publishedAt.getTime()
  );

const pageDescription =
  "Archive of blog posts by Matias Kreder, including cloud, AI, engineering, and legacy WordPress content.";
const pageUrl = new URL("/blog/", site.url).toString();
---

<BaseLayout
  title="Archive — Matias Kreder"
  description={pageDescription}
  canonicalUrl={pageUrl}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Archive — Matias Kreder",
    url: pageUrl,
    description: pageDescription
  }}
>
  <section class="section">
    <div class="container">
      <h1 class="archive-title">Archive</h1>
      <p class="archive-desc">
        Legacy posts imported from WordPress. New posts are published on dev.to.
      </p>

      {posts.length > 0 ? (
        <div class="post-list">
          {posts.map((post) => (
            <a class="post-item" href={`/blog/${post.id}/`}>
              <div class="post-item-title">{post.data.title}</div>
              <div class="post-item-desc">{post.data.description}</div>
              <div class="post-item-meta">
                <span>{formatDate(post.data.publishedAt)}</span>
                {post.data.tags.length > 0 && (
                  <div class="post-item-tags">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="empty">No posts yet.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .archive-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .archive-desc {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .empty {
    font-size: 0.875rem;
    color: var(--text-muted);
  }
</style>
