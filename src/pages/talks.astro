---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import { talks } from "../data/talks";
import { formatDate } from "../lib/format";

const sortedTalks = [...talks].sort(
  (left, right) => new Date(right.date).getTime() - new Date(left.date).getTime()
);
const featuredTalks = sortedTalks.filter((talk) => talk.featured).slice(0, 8);

const pageDescription =
  "Community activity, talks, workshops, and sessions by Matias Kreder across Argentina, LATAM, and global AWS and AI communities.";
const pageUrl = new URL("/talks/", site.url).toString();
---

<BaseLayout
  title="Community — Matias Kreder"
  description={pageDescription}
  canonicalUrl={pageUrl}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Community — Matias Kreder",
    url: pageUrl,
    description: pageDescription,
    mainEntity: {
      "@type": "ItemList",
      itemListElement: sortedTalks.slice(0, 12).map((talk, index) => ({
        "@type": "ListItem",
        position: index + 1,
        item: {
          "@type": "Event",
          name: talk.title,
          eventAttendanceMode:
            talk.deliveryMode === "Online"
              ? "https://schema.org/OnlineEventAttendanceMode"
              : "https://schema.org/OfflineEventAttendanceMode",
          eventStatus: "https://schema.org/EventCompleted",
          startDate: new Date(talk.date).toISOString(),
          location:
            talk.deliveryMode === "Online"
              ? {
                  "@type": "VirtualLocation",
                  url: talk.url
                }
              : {
                  "@type": "Place",
                  name: talk.location
                },
          inLanguage: talk.language,
          url: talk.url
        }
      }))
    }
  }}
>
  <section class="section">
    <div class="container">
      <p class="section-label">Community</p>
      <h1 class="page-title">Talks, workshops, and community<br/>engagement accross the region.</h1>
      <p class="page-desc">
        I'm an AI engineering community builder and user group leader based in Buenos Aires.
        I give talks, run workshops, and collaborate with other communities across Argentina,
        LATAM, and the broader AWS and AI ecosystem.
      </p>
    </div>
  </section>

  {featuredTalks.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>Highlights</h2>
        </div>
        <div class="post-list">
          {featuredTalks.map((talk) => (
            <a class="post-item talk-item" href={talk.url} target="_blank" rel="noreferrer">
              <div class="talk-location">{talk.location}</div>
              <div class="post-item-title">{talk.title}</div>
              <div class="post-item-desc">{talk.summary}</div>
              <div class="post-item-meta">
                <span>{formatDate(talk.date)}</span>
                <span>{talk.activityType}</span>
                <span>{talk.language}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Timeline</h2>
      </div>
      <div class="post-list">
        {sortedTalks.map((talk) => (
          <a class="post-item talk-item" href={talk.url} target="_blank" rel="noreferrer">
            <div class="talk-location">{talk.location}</div>
            <div class="post-item-title">{talk.title}</div>
            <div class="post-item-desc">{talk.summary}</div>
            <div class="post-item-meta">
              <span>{formatDate(talk.date)}</span>
              <span>{talk.activityType}</span>
              <span>{talk.language}</span>
              {talk.sourceLabel && <span>{talk.sourceLabel}</span>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .page-desc {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 640px;
  }

  .talk-item {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .talk-location {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }
</style>
