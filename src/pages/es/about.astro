---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { certifications, site } from "../../data/site";
import { t, formatDateLocalized } from "../../i18n/utils";

const lang = "es";
const pageDescription = t(lang, "meta.aboutDescription");
const pageUrl = new URL("/es/about/", site.url).toString();
---

<BaseLayout
  lang={lang}
  title={`${t(lang, "about.label")} — Matias Kreder`}
  description={pageDescription}
  canonicalUrl={pageUrl}
  ogType="profile"
  jsonLd={[
    { "@context": "https://schema.org", "@type": "ProfilePage", name: "About Matias Kreder", url: pageUrl, description: pageDescription },
    { "@context": "https://schema.org", "@type": "Person", name: "Matias Kreder", url: pageUrl, sameAs: site.links.map((l) => l.href), jobTitle: "CTO", homeLocation: { "@type": "Place", name: "Buenos Aires, Argentina" } }
  ]}
>
  <section class="section">
    <div class="container">
      <p class="about-label">{t(lang, "about.label")}</p>
      <h1 class="about-title">Matias Kreder</h1>
      <div class="about-body">
        <p>{t(lang, "about.bio1")}</p>
        <p>{t(lang, "about.bio2")}</p>
        <p>{t(lang, "about.bio3")}</p>
      </div>
      <div class="links-row">
        {site.links.map((link) => (
          <a class="link-chip" href={link.href} target="_blank" rel="noreferrer">
            {link.label} &nearr;
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="certs-title">{t(lang, "section.certifications")}</h2>
      <div class="cert-list">
        {certifications.map((cert) => (
          cert.credlyUrl ? (
            <a class="cert-item cert-link" href={cert.credlyUrl} target="_blank" rel="noreferrer">
              <div class="cert-name">{cert.name} <span class="cert-arrow">&nearr;</span></div>
              <div class="cert-meta">{t(lang, "link.expires")} {cert.expires}</div>
            </a>
          ) : (
            <div class="cert-item">
              <div class="cert-name">{cert.name}</div>
              <div class="cert-meta">{t(lang, "link.expires")} {cert.expires}</div>
            </div>
          )
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 0.5rem; }
  .about-title { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; letter-spacing: -0.03em; margin-bottom: 1.5rem; }
  .about-body p { font-size: 1.0625rem; line-height: 1.75; color: var(--text-secondary); }
  .about-body p + p { margin-top: 1rem; }
  .links-row { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1.5rem; }
  .link-chip { font-size: 0.8125rem; font-weight: 500; padding: 0.375rem 0.875rem; border-radius: 999px; border: 1px solid var(--border); color: var(--text-secondary); transition: all 0.15s; }
  .link-chip:hover { border-color: var(--text); color: var(--text); }
  .certs-title { font-size: 1.25rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1rem; }
  .cert-list { display: flex; flex-direction: column; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .cert-item { display: flex; align-items: baseline; justify-content: space-between; padding: 0.75rem 1.25rem; gap: 1rem; }
  .cert-item + .cert-item { border-top: 1px solid var(--border); }
  .cert-link { text-decoration: none; transition: background 0.15s; }
  .cert-link:hover { background: var(--surface-hover); }
  .cert-arrow { color: var(--text-muted); font-size: 0.75rem; }
  .cert-name { font-size: 0.875rem; font-weight: 500; }
  .cert-meta { font-size: 0.75rem; color: var(--text-muted); white-space: nowrap; }
  @media (max-width: 640px) { .cert-item { flex-direction: column; gap: 0.125rem; } }
</style>
