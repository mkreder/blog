---
import BaseLayout from "../layouts/BaseLayout.astro";
import { certifications } from "../data/site";
---

<BaseLayout title="Certifications | Matias Kreder">
  <header class="page-header">
    <p class="eyebrow">Certifications</p>
    <h1>AWS-heavy, AI-forward credential set.</h1>
    <p>
      This page is ready for a future Credly profile link. For now it renders the certification
      inventory directly from site data so it stays versioned with the rest of the site.
    </p>
  </header>

  <section class="grid grid-2">
    {certifications.map((item) => (
      <article class="card">
        <p class="eyebrow">{item.issuer}</p>
        <h3>{item.name}</h3>
        <p>Expires {item.expires}</p>
        {item.credlyUrl ? (
          <a href={item.credlyUrl} target="_blank" rel="noreferrer">View on Credly</a>
        ) : (
          <p>Credly link can be added per certification or replaced with a public profile URL.</p>
        )}
      </article>
    ))}
  </section>
</BaseLayout>
